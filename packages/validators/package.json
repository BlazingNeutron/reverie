    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "bunchee": "^6.9.4",
    "eslint": "^9.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
