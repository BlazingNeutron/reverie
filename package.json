{
  "name": "reverie-notes",
  "version": "0.0.2",
  "license": "MIT",
  "description": "Collaborative Note app for all of your dreamy and thoughtful ideas.",
  "scripts": {
    "build": "turbo run build",
    "check:licenses": "node scripts/check-licenses.cjs",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean",
    "db:reset": "turbo run db:reset",
    "db:migrate": "turbo run db:migrate",
    "dev": "turbo run dev",
    "format": "prettier * --write",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:updateSnapshots": "turbo run test:updateSnapshots"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "packageManager": "npm@11.4.2",
  "devDependencies": {
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.8.7"
  }
}
