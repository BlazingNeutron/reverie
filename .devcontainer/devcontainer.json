{
  "name": "Reverie Notes",
  "image": "mcr.microsoft.com/devcontainers/javascript-node",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-vscode.makefile-tools",
        "vitest.explorer",
        "github.vscode-github-actions",
        "bradlc.vscode-tailwindcss",
        "ms-ossdata.vscode-pgsql",
        "EditorConfig.EditorConfig"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers-extra/features/supabase-cli": "latest",
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },
  "runArgs": [
    "--env-file",
    "${localWorkspaceFolder}/.env",
    "--privileged",
    "-v",
    "/dev/bus/usb:/dev/bus/usb"
  ],
  "containerEnv": {
    "PGSSLMODE": "disable",
    "DEVCONTAINER": "true" // this let's scripts know that we are inside a devcontainer
  },
  // Execute these on the docker host so that supabase is started for the dev environment
  "initializeCommand": "npm i supabase && npx supabase start",
  // Ensure turbo and other dependencies are installed
  "postCreateCommand": "sudo apt update && sudo apt upgrade -y && npm install -g npm@11.12.1 && npm i turbo -g && npm i",
  // Start supabase within the devcontainer and connec the devcontainer to the supabase network
  "postStartCommand": "supabase start && docker network connect supabase_network_reverie $HOSTNAME"
}
