{
  "name": "Reverie Notes",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-vscode.makefile-tools",
        "vitest.explorer",
        "github.vscode-github-actions",
        "bradlc.vscode-tailwindcss",
        "ms-ossdata.vscode-pgsql",
        "EditorConfig.EditorConfig"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers-extra/features/supabase-cli": "latest",
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "containerEnv": {
    "PGSSLMODE": "disable",
    "CODESPACES": "true",
    "DEVCONTAINER": "true"
  },
  "postCreateCommand": "npm i turbo -g && npm i",
  "postStartCommand": "supabase start && docker network connect supabase_network_reverie $HOSTNAME",
  "initializeCommand": "npx supabase start"
}
