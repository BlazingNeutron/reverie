{
  "compilerOptions": {
    "jsx": "react",
    "target": "esnext",
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "./src/**/__tests__/*test.ts"]
}
