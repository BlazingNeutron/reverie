{
  "name": "@repo/reverie-notes-web-app",
  "version": "0.0.0",
  "description": "Note taking app for all of your dreamy, thoughtful, deep thinking and shared ideas.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:reset": "supabase db reset --yes --db-url $SUPABASE_DB_URL",
    "db:migrate": "supabase migration new migration_name",
    "db:diff": "supabase db diff --db-url $SUPABASE_DB_URL",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.config.it.ts",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.2",
    "istanbul-reporter-html-dark": "^1.0.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vite-plugin-rnw": "^0.0.11",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/themes": "^3.3.0",
    "@react-router/dev": "^7.14.0",
    "@react-router/fs-routes": "^7.14.0",
    "@react-router/serve": "^7.14.0",
    "@repo/ui": "^0.0.0",
    "@repo/validators": "0.0.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "buffer": "^6.0.3",
    "cors": "^2.8.6",
    "quill": "^2.0.2",
    "quill-cursors": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "y-quill": "^1.0.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12"
  }
